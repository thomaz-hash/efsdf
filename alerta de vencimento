<div
  class="export-wrapper"
  style="
    width: 375px;
    min-height: 812px;
    position: relative;
    font-family: var(--font-family-body);
    background-color: var(--background);
  "
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <html>
    <head>
      <!-- MANTIDO: todo seu Tailwind e variáveis -->
    </head>

    <body>
      <div class="relative flex flex-col w-full h-[812px] bg-[#FCFDFB] text-foreground font-body overflow-hidden">
        
        <!-- HEADER -->
        <div class="flex items-center justify-between px-6 pt-14 pb-4">
          <button class="flex items-center justify-center w-10 h-10 -ml-2 text-[#1A461A]">
            <iconify-icon icon="lucide:chevron-left" class="size-[28px]"></iconify-icon>
          </button>

          <h1 class="text-[18px] font-bold text-[#1A461A]">
            Alertas
          </h1>

          <button class="flex items-center justify-center w-10 h-10 -mr-2 text-[#1A461A]">
            <iconify-icon icon="lucide:bell" class="size-[24px]"></iconify-icon>
          </button>
        </div>

        <!-- TITLE -->
        <div class="px-6 mt-4 mb-6">
          <h2 class="text-[17px] font-bold text-[#1A461A] tracking-tight">
            Produtos próximos do vencimento
          </h2>
        </div>

        <!-- LIST -->
        <div class="flex-1 px-6 overflow-y-auto pb-24">

          <!-- CARD 1 -->
          <div class="flex items-center w-full px-4 py-4 rounded-[16px] bg-[#EAF6E3] mb-4 shadow-sm">
            <div class="mr-4">
              <div class="w-[48px] h-[48px] flex items-center justify-center rounded-full border-2 border-[#4D8F3A] text-[#4D8F3A]">
                <iconify-icon icon="lucide:package" class="size-[24px]"></iconify-icon>
              </div>
            </div>

            <div class="flex-1">
              <h3 class="text-[15px] font-semibold text-[#1A461A]">Leite Integral</h3>
              <p class="text-[13px] text-[#1A461A] opacity-80">Vence em 5 dias</p>
              <p class="text-[12px] text-[#1A461A] opacity-60">15/05/2025</p>
            </div>

            <iconify-icon icon="lucide:chevron-right" class="size-[20px] text-[#4D8F3A]"></iconify-icon>
          </div>

          <!-- CARD 2 -->
          <div class="flex items-center w-full px-4 py-4 rounded-[16px] bg-[#FDEAC5] mb-4 shadow-sm">
            <div class="mr-4">
              <div class="w-[48px] h-[48px] flex items-center justify-center rounded-full bg-[#F4A82F] text-white">
                <iconify-icon icon="lucide:package" class="size-[24px]"></iconify-icon>
              </div>
            </div>

            <div class="flex-1">
              <h3 class="text-[15px] font-semibold text-[#1A1A1A]">Queijo Mussarela</h3>
              <p class="text-[13px] text-[#1A1A1A] opacity-80">Vence amanhã</p>
              <p class="text-[12px] text-[#1A1A1A] opacity-60">10/05/2025</p>
            </div>

            <iconify-icon icon="lucide:chevron-right" class="size-[20px] text-[#F4A82F]"></iconify-icon>
          </div>

          <!-- CARD 3 -->
          <div class="flex items-center w-full px-4 py-4 rounded-[16px] bg-[#F9DBDD] mb-4 shadow-sm">
            <div class="mr-4">
              <div class="w-[48px] h-[48px] flex items-center justify-center rounded-full bg-[#DF5356] text-white">
                <iconify-icon icon="lucide:package" class="size-[24px]"></iconify-icon>
              </div>
            </div>

            <div class="flex-1">
              <h3 class="text-[15px] font-semibold text-[#1A1A1A]">Iogurte Natural</h3>
              <p class="text-[13px] text-[#1A1A1A] opacity-80">Vence hoje</p>
              <p class="text-[12px] text-[#1A1A1A] opacity-60">09/05/2025</p>
            </div>

            <iconify-icon icon="lucide:chevron-right" class="size-[20px] text-[#DF5356]"></iconify-icon>
          </div>

        </div>

        <!-- BOTTOM NAV -->
        <div class="absolute bottom-0 left-0 w-full h-20 bg-card border-t border-border flex justify-around items-center px-4 pb-2 rounded-t-[24px] shadow-[0_-4px_24px_rgba(0,0,0,0.06)]">
          
          <button class="flex flex-col items-center text-muted-foreground">
            <iconify-icon icon="lucide:home" class="size-[24px]"></iconify-icon>
            <span class="text-[10px]">Despensa</span>
          </button>

          <button class="flex flex-col items-center text-primary">
            <iconify-icon icon="lucide:bell" class="size-[24px]"></iconify-icon>
            <span class="text-[10px]">Alertas</span>
          </button>

          <button class="flex flex-col items-center text-muted-foreground">
            <iconify-icon icon="lucide:utensils" class="size-[24px]"></iconify-icon>
            <span class="text-[10px]">Receitas</span>
          </button>

          <button class="flex flex-col items-center text-muted-foreground">
            <iconify-icon icon="lucide:user" class="size-[24px]"></iconify-icon>
            <span class="text-[10px]">Perfil</span>
          </button>

        </div>
      </div>
    </body>
  </html>

  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
</div>
